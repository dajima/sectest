# ==============================================
# Sectest Environment Variables
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: .env contains SECRETS — never commit it to git.
# ==============================================

# ==============================================
# MODE 1: Direct Mode (recommended for dev/test)
# ==============================================
# Set LLM_API_BASE to connect directly to any OpenAI-compatible API.
# LiteLLM Proxy is NOT required in this mode.

# Model identifier (e.g. deepseek/deepseek-v4-flash, gpt-4o, openai/gpt-4o)
LLM_MODEL=deepseek/deepseek-v4-flash

# API key for the provider
LLM_API_KEY=sk-...

# Base URL for the OpenAI-compatible API endpoint (must include /v1)
LLM_API_BASE=https://api.deepseek.com/v1

# ==============================================
# MODE 2: LiteLLM Proxy Mode (multi-provider fallback)
# ==============================================
# When LLM_API_BASE is NOT set, the platform uses LiteLLM Proxy.
# Start the proxy first:  docker compose up litellm -d
#
# Proxy config lives in config/litellm_config.yaml — add your models there.

# --- LLM Provider API Keys (for LiteLLM Proxy) ---
# These are read by the LiteLLM Proxy container, NOT the sectest backend.
# The sectest backend only knows the LiteLLM master key.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- LiteLLM Proxy Connection ---
# Master key — must match general_settings.master_key in litellm_config.yaml
LITELLM_MASTER_KEY=sk-sectest-lite

# Base URL for LiteLLM Proxy (only used when LLM_API_BASE is not set)
LITELLM_BASE_URL=http://localhost:4000/v1

# API key the backend sends to LiteLLM Proxy
# Must match LITELLM_MASTER_KEY above.
LITELLM_API_KEY=sk-sectest-lite

# ==============================================
# LEGACY (still works, but LLM_MODEL is preferred)
# ==============================================
# DEFAULT_MODEL=gpt-4o
