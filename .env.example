# ==============================================
# Sectest Environment Variables
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: .env contains SECRETS — never commit it to git.
# ==============================================

# --- LLM Provider API Keys ---
# OpenAI API key (required for GPT-4o primary model)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for Claude Sonnet 4 fallback model)
ANTHROPIC_API_KEY=sk-ant-...

# --- LiteLLM Proxy Configuration ---
# Master key for authenticating with the LiteLLM Proxy
# This is the key the backend uses; LiteLLM Proxy validates it.
LITELLM_MASTER_KEY=sk-sectest-lite

# Base URL for the LiteLLM Proxy OpenAI-compatible API endpoint
# Must include the /v1 suffix for OpenAI SDK compatibility.
LITELLM_BASE_URL=http://localhost:4000/v1

# API key the backend sends to the LiteLLM Proxy
# Must match LITELLM_MASTER_KEY configured in LiteLLM Proxy.
LITELLM_API_KEY=sk-sectest-lite
